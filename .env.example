# Supabase project credentials.
# Copy this file to `.env` and fill in real values.
# Note: EXPO_PUBLIC_* vars are inlined into the client bundle by Expo at
# build time, so anything here is shipped to every user. That is acceptable
# for the Supabase *anon/publishable* key ONLY if Row Level Security is
# enabled on every table. Never put service_role or any secret key here.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_replace_me
