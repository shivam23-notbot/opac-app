{
  "name": "opac-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "type": "commonjs",
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--no-experimental-require-module expo start",
    "android": "cross-env NODE_OPTIONS=--no-experimental-require-module expo start --android",
    "ios": "cross-env NODE_OPTIONS=--no-experimental-require-module expo start --ios",
    "web": "cross-env NODE_OPTIONS=--no-experimental-require-module expo start --web",
    "build:web": "expo export --platform web",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,js,json}\""
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/source-serif-4": "^0.4.1",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.105.4",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^1.14.0",
    "nanoid": "^5.1.11",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.8.3",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.13"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "babel-preset-expo": "^55.0.21",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-config-expo": "^55.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2"
  },
  "private": true
}
